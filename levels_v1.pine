// =============================================================================
// LTP Levels Indicator v1.0
// Shows PM levels (PMH/PML) and key target levels from the strategy.
// Use on 2min or 5min charts during RTH.
// =============================================================================
//@version=6
indicator("LTP Levels v1", overlay=true, max_lines_count=500, max_labels_count=500)

// =============================================================================
// INPUTS
// =============================================================================
grp_pm = "Pre-Market Levels"
show_pm    = input.bool(true,          "Show PMH / PML",   group=grp_pm)
col_pmh    = input.color(color.white,  "PMH Color",        group=grp_pm)
col_pml    = input.color(color.white,  "PML Color",        group=grp_pm)
pm_width   = input.int(2, "Width",     minval=1, maxval=4, group=grp_pm)
pm_style   = input.string("Solid",     "Style", options=["Solid", "Dashed", "Dotted"], group=grp_pm)

grp_kl = "Key Levels (Targets)"
show_kl      = input.bool(true,          "Show Key Levels",     group=grp_kl)
col_kl       = input.color(color.yellow, "Color",               group=grp_kl)
kl_width     = input.int(1, "Width",     minval=1, maxval=4,    group=grp_kl)
kl_min_space = input.float(1.00,         "Min Spacing ($)",     group=grp_kl, minval=0.25, step=0.25)
kl_adr_mult  = input.float(1.0,         "ADR Multiplier",      group=grp_kl, minval=0.5, maxval=3.0, step=0.1,
     tooltip="Range = multiplier x 14-day ADR per side from PM boundaries.")
kl_max_side  = input.int(5,             "Max Levels Per Side",  group=grp_kl, minval=2, maxval=12)
kl_show_labels = input.bool(true,        "Show Level Labels",   group=grp_kl)

grp_pm_buf = "PM Buffer Zone"
show_pm_zone = input.bool(true,          "Show PM Buffer Zone", group=grp_pm_buf)
col_pm_zone  = input.color(color.new(color.gray, 85), "Zone Color", group=grp_pm_buf)
pm_buffer    = input.float(0.80,         "Buffer ($)",          group=grp_pm_buf, minval=0.10, step=0.10,
     tooltip="Exclusion zone around PMH/PML. PCs inside this zone are too close to PM.")

// =============================================================================
// HELPERS
// =============================================================================
is_new_day = ta.change(time("D")) != 0
is_rth     = not na(time(timeframe.period, "0930-1600", "America/New_York"))

_line_style(s) =>
    s == "Dashed" ? line.style_dashed : s == "Dotted" ? line.style_dotted : line.style_solid

// =============================================================================
// PRE-MARKET HIGH / LOW
// Computed from ETH bars before 9:30 ET on each day.
// =============================================================================
var float pmh = na
var float pml = na
var bool  pm_set = false

// Detect pre-market: before RTH
is_premarket = not is_rth and session.ismarket == false

// Use request.security on daily timeframe to get prior day's PM levels cleanly
// Alternative: track ETH bars manually
[d_pmh, d_pml] = request.security(syminfo.tickerid, "D", [high, low], lookahead=barmerge.lookahead_on)

// Simple approach: use the first bar of RTH to capture PM range
// For intraday: track pre-market bars
var float today_pm_high = na
var float today_pm_low  = na

if is_new_day
    today_pm_high := na
    today_pm_low  := na
    pm_set        := false

// Before RTH opens, track the high/low
if not is_rth and not na(high)
    today_pm_high := na(today_pm_high) ? high : math.max(today_pm_high, high)
    today_pm_low  := na(today_pm_low)  ? low  : math.min(today_pm_low,  low)

// Lock PM levels at RTH open
if is_rth and not pm_set and not na(today_pm_high) and not na(today_pm_low)
    pmh    := today_pm_high
    pml    := today_pm_low
    pm_set := true

// =============================================================================
// PM LEVEL LINES
// =============================================================================
var line ln_pmh = na
var line ln_pml = na
var line ln_pmh_buf_hi = na
var line ln_pmh_buf_lo = na
var line ln_pml_buf_hi = na
var line ln_pml_buf_lo = na
var label lbl_pmh = na
var label lbl_pml = na

if is_rth and pm_set and show_pm
    // Extend PMH line
    if not na(ln_pmh)
        line.set_x2(ln_pmh, bar_index)
        line.set_x2(ln_pml, bar_index)
    else
        ln_pmh := line.new(bar_index, pmh, bar_index, pmh, color=col_pmh, width=pm_width, style=_line_style(pm_style))
        ln_pml := line.new(bar_index, pml, bar_index, pml, color=col_pml, width=pm_width, style=_line_style(pm_style))
        lbl_pmh := label.new(bar_index, pmh, "PMH " + str.tostring(pmh, format.mintick), style=label.style_none, textcolor=col_pmh, size=size.small)
        lbl_pml := label.new(bar_index, pml, "PML " + str.tostring(pml, format.mintick), style=label.style_none, textcolor=col_pml, size=size.small)

    // Update label positions
    if not na(lbl_pmh)
        label.set_x(lbl_pmh, bar_index + 3)
        label.set_x(lbl_pml, bar_index + 3)

// PM Buffer zone (box fill)
if is_rth and pm_set and show_pm_zone
    if not na(ln_pmh_buf_hi)
        line.set_x2(ln_pmh_buf_hi, bar_index)
        line.set_x2(ln_pmh_buf_lo, bar_index)
        line.set_x2(ln_pml_buf_hi, bar_index)
        line.set_x2(ln_pml_buf_lo, bar_index)
    else
        ln_pmh_buf_hi := line.new(bar_index, pmh + pm_buffer, bar_index, pmh + pm_buffer, color=col_pm_zone, width=1, style=line.style_dotted)
        ln_pmh_buf_lo := line.new(bar_index, pmh - pm_buffer, bar_index, pmh - pm_buffer, color=col_pm_zone, width=1, style=line.style_dotted)
        ln_pml_buf_hi := line.new(bar_index, pml + pm_buffer, bar_index, pml + pm_buffer, color=col_pm_zone, width=1, style=line.style_dotted)
        ln_pml_buf_lo := line.new(bar_index, pml - pm_buffer, bar_index, pml - pm_buffer, color=col_pm_zone, width=1, style=line.style_dotted)

// =============================================================================
// KEY LEVELS (TARGETS)
// Priority: Hourly 200 SMA > $50 Psych > Daily OHLC (10 days) > Hourly OHLC
// =============================================================================

// --- Daily OHLC levels (last 10 trading days) ---
get_daily_levels() =>
    levels = array.new_float()
    priorities = array.new_float()
    for i = 1 to 10
        d_o = request.security(syminfo.tickerid, "D", open[i], lookahead=barmerge.lookahead_on)
        d_h = request.security(syminfo.tickerid, "D", high[i], lookahead=barmerge.lookahead_on)
        d_l = request.security(syminfo.tickerid, "D", low[i],  lookahead=barmerge.lookahead_on)
        d_c = request.security(syminfo.tickerid, "D", close[i], lookahead=barmerge.lookahead_on)
        if not na(d_h)
            // Prior day gets highest priority, decays for older days
            decay = i == 1 ? 30.0 : math.max(30.0 - i * 2.5, 1.5)
            array.push(levels, d_h)
            array.push(priorities, i == 1 ? 10.5 : decay)
            array.push(levels, d_l)
            array.push(priorities, i == 1 ? 10.5 : decay)
            array.push(levels, d_o)
            array.push(priorities, i == 1 ? 30.0 : decay * 0.5)
            array.push(levels, d_c)
            array.push(priorities, i == 1 ? 30.0 : decay * 0.5)
    [levels, priorities]

// --- $50 Psychological levels ---
get_psych_levels(price_low, price_high) =>
    levels = array.new_float()
    priorities = array.new_float()
    start = math.floor(price_low / 50) * 50
    p = start
    while p <= price_high
        if p > 0
            array.push(levels, p)
            // $100 levels get extra priority
            array.push(priorities, p % 100 == 0 ? 45.0 : 40.0)
        p += 50
    [levels, priorities]

// --- ADR for distance cap ---
adr_val = request.security(syminfo.tickerid, "D", ta.atr(14), lookahead=barmerge.lookahead_on)
max_dist = nz(adr_val, 15.0) * kl_adr_mult

// --- Hourly 200 SMA ---
sma_200_1h = request.security(syminfo.tickerid, "60", ta.sma(close, 200), lookahead=barmerge.lookahead_on)

// --- Collect and filter key levels ---
var line[] kl_lines  = array.new_line()
var label[] kl_labels = array.new_label()

if is_rth and pm_set and show_kl and barstate.islast
    // Clean up old lines/labels
    for i = 0 to array.size(kl_lines) - 1
        line.delete(array.get(kl_lines, i))
    for i = 0 to array.size(kl_labels) - 1
        label.delete(array.get(kl_labels, i))
    array.clear(kl_lines)
    array.clear(kl_labels)

    // Gather all candidate levels
    all_levels = array.new_float()
    all_prios  = array.new_float()

    // Hourly 200 SMA
    if not na(sma_200_1h)
        array.push(all_levels, sma_200_1h)
        array.push(all_prios, 50.0)

    // $50 psych levels
    [psych_lvls, psych_prios] = get_psych_levels(pml - max_dist, pmh + max_dist)
    for i = 0 to array.size(psych_lvls) - 1
        array.push(all_levels, array.get(psych_lvls, i))
        array.push(all_prios, array.get(psych_prios, i))

    // Daily OHLC
    [daily_lvls, daily_prios] = get_daily_levels()
    for i = 0 to array.size(daily_lvls) - 1
        array.push(all_levels, array.get(daily_lvls, i))
        array.push(all_prios, array.get(daily_prios, i))

    // Filter: outside PM zone, within ADR distance
    above_levels = array.new_float()
    above_prios  = array.new_float()
    below_levels = array.new_float()
    below_prios  = array.new_float()

    for i = 0 to array.size(all_levels) - 1
        lvl = array.get(all_levels, i)
        pri = array.get(all_prios, i)

        // Must be outside PM buffer zone
        if lvl > pmh + pm_buffer and lvl <= pmh + max_dist
            array.push(above_levels, lvl)
            array.push(above_prios, pri)
        else if lvl < pml - pm_buffer and lvl >= pml - max_dist
            array.push(below_levels, lvl)
            array.push(below_prios, pri)

    // Sort and space-filter above levels (closest to PMH first)
    // Simple bubble sort by distance from PMH
    for i = 0 to array.size(above_levels) - 2
        for j = i + 1 to array.size(above_levels) - 1
            if array.get(above_levels, j) < array.get(above_levels, i)
                tmp_l = array.get(above_levels, i)
                tmp_p = array.get(above_prios, i)
                array.set(above_levels, i, array.get(above_levels, j))
                array.set(above_prios, i, array.get(above_prios, j))
                array.set(above_levels, j, tmp_l)
                array.set(above_prios, j, tmp_p)

    // Space filter: keep levels that are min_spacing apart
    final_above = array.new_float()
    last_kept = pmh
    count_above = 0
    for i = 0 to array.size(above_levels) - 1
        if count_above >= kl_max_side
            break
        lvl = array.get(above_levels, i)
        if lvl - last_kept >= kl_min_space
            array.push(final_above, lvl)
            last_kept := lvl
            count_above += 1

    // Sort below levels (closest to PML first = highest value first)
    for i = 0 to array.size(below_levels) - 2
        for j = i + 1 to array.size(below_levels) - 1
            if array.get(below_levels, j) > array.get(below_levels, i)
                tmp_l = array.get(below_levels, i)
                tmp_p = array.get(below_prios, i)
                array.set(below_levels, i, array.get(below_levels, j))
                array.set(below_prios, i, array.get(below_prios, j))
                array.set(below_levels, j, tmp_l)
                array.set(below_prios, j, tmp_p)

    final_below = array.new_float()
    last_kept := pml
    count_below = 0
    for i = 0 to array.size(below_levels) - 1
        if count_below >= kl_max_side
            break
        lvl = array.get(below_levels, i)
        if last_kept - lvl >= kl_min_space
            array.push(final_below, lvl)
            last_kept := lvl
            count_below += 1

    // Draw above levels
    for i = 0 to array.size(final_above) - 1
        lvl = array.get(final_above, i)
        ln = line.new(bar_index - 50, lvl, bar_index + 10, lvl, color=col_kl, width=kl_width, style=line.style_dashed)
        array.push(kl_lines, ln)
        if kl_show_labels
            lbl = label.new(bar_index + 10, lvl, str.tostring(lvl, format.mintick), style=label.style_none, textcolor=col_kl, size=size.tiny)
            array.push(kl_labels, lbl)

    // Draw below levels
    for i = 0 to array.size(final_below) - 1
        lvl = array.get(final_below, i)
        ln = line.new(bar_index - 50, lvl, bar_index + 10, lvl, color=col_kl, width=kl_width, style=line.style_dashed)
        array.push(kl_lines, ln)
        if kl_show_labels
            lbl = label.new(bar_index + 10, lvl, str.tostring(lvl, format.mintick), style=label.style_none, textcolor=col_kl, size=size.tiny)
            array.push(kl_labels, lbl)
