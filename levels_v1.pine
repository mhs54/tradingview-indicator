// =============================================================================
// LTP Levels Indicator v1.0
// Matches backtest engine levels.py as closely as Pine Script allows.
// Missing: hourly density clustering, ETH H/L exceedance, gap fill midpoints.
// =============================================================================
//@version=6
indicator("LTP Levels v1", overlay=true, max_bars_back=501, max_lines_count=500, max_labels_count=500)

// =============================================================================
// INPUTS
// =============================================================================
grp_pm = "Pre-Market Levels"
show_pm    = input.bool(true,          "Show PMH / PML",   group=grp_pm)
col_pmh    = input.color(color.white,  "PMH Color",        group=grp_pm)
col_pml    = input.color(color.white,  "PML Color",        group=grp_pm)
pm_width   = input.int(2, "Width",     minval=1, maxval=4, group=grp_pm)

grp_buf = "PM Buffer Zone"
show_buf   = input.bool(true,          "Show Buffer Zone", group=grp_buf)
col_buf    = input.color(color.new(color.gray, 85), "Zone Color", group=grp_buf)
pm_buffer  = input.float(0.80,         "Buffer ($)",       group=grp_buf, minval=0.10, step=0.10)

grp_kl = "Key Levels (Targets)"
show_kl       = input.bool(true,          "Show Key Levels",     group=grp_kl)
col_kl        = input.color(color.yellow, "Color",               group=grp_kl)
kl_width      = input.int(1, "Width",     minval=1, maxval=4,    group=grp_kl)
kl_min_space  = input.float(1.00,         "Min Spacing ($)",     group=grp_kl, minval=0.10, step=0.10)
kl_adr_mult   = input.float(1.5,          "Max Dist (ADR mult)", group=grp_kl, minval=0.5, maxval=3.0, step=0.1)
kl_max_side   = input.int(5,              "Max Levels Per Side", group=grp_kl, minval=2, maxval=12)
show_labels   = input.bool(true,          "Show Level Labels",   group=grp_kl)
col_sma       = input.color(#FF69B4,      "200 SMA Level Color", group=grp_kl)
col_ath       = input.color(color.lime,   "ATH Level Color",     group=grp_kl)

// =============================================================================
// SESSION DETECTION
// =============================================================================
is_rth     = not na(time(timeframe.period, "0930-1600", "America/New_York"))
is_new_day = ta.change(time("D")) != 0

// =============================================================================
// PRE-MARKET HIGH / LOW
// =============================================================================
var float pmh = na
var float pml = na
var float today_pm_high = na
var float today_pm_low  = na
var bool  pm_locked = false

if is_new_day
    today_pm_high := na
    today_pm_low  := na
    pm_locked     := false

if not is_rth and not pm_locked
    today_pm_high := na(today_pm_high) ? high : math.max(today_pm_high, high)
    today_pm_low  := na(today_pm_low)  ? low  : math.min(today_pm_low,  low)

if is_rth and not pm_locked and not na(today_pm_high)
    pmh       := today_pm_high
    pml       := today_pm_low
    pm_locked := true

// =============================================================================
// ADR (14-day average daily range)
// =============================================================================
adr_val = request.security(syminfo.tickerid, "D", ta.sma(high - low, 14), lookahead=barmerge.lookahead_on)
adr = nz(adr_val, 15.0)
max_dist = adr * kl_adr_mult

// =============================================================================
// HOURLY 200 SMA
// =============================================================================
sma_200_1h = request.security(syminfo.tickerid, "60", ta.sma(close, 200), lookahead=barmerge.lookahead_on)

// =============================================================================
// ATH / ATL DETECTION
// =============================================================================
all_time_high = request.security(syminfo.tickerid, "D", ta.highest(high, 500), lookahead=barmerge.lookahead_on)
all_time_low  = request.security(syminfo.tickerid, "D", ta.lowest(low, 500),   lookahead=barmerge.lookahead_on)
is_ath = not na(pmh) and (all_time_high <= pmh + 0.50)
is_atl = not na(pml) and (all_time_low  >= pml - 0.50)

// =============================================================================
// DAILY OHLC LEVELS — request prior 25 days
// Uses engine priority: prior day O/C=30, H/L=10.5; day 2+ H/L=max(30-i,5), O/C=max(10.5-i*0.5,1.5)
// =============================================================================
// Pre-fetch daily OHLC for days 1-10 (Pine cannot use loop vars in request.security)
[dh1,dl1,do1,dc1] = request.security(syminfo.tickerid,"D",[high[1],low[1],open[1],close[1]],lookahead=barmerge.lookahead_on)
[dh2,dl2,do2,dc2] = request.security(syminfo.tickerid,"D",[high[2],low[2],open[2],close[2]],lookahead=barmerge.lookahead_on)
[dh3,dl3,do3,dc3] = request.security(syminfo.tickerid,"D",[high[3],low[3],open[3],close[3]],lookahead=barmerge.lookahead_on)
[dh4,dl4,do4,dc4] = request.security(syminfo.tickerid,"D",[high[4],low[4],open[4],close[4]],lookahead=barmerge.lookahead_on)
[dh5,dl5,do5,dc5] = request.security(syminfo.tickerid,"D",[high[5],low[5],open[5],close[5]],lookahead=barmerge.lookahead_on)
[dh6,dl6,do6,dc6] = request.security(syminfo.tickerid,"D",[high[6],low[6],open[6],close[6]],lookahead=barmerge.lookahead_on)
[dh7,dl7,do7,dc7] = request.security(syminfo.tickerid,"D",[high[7],low[7],open[7],close[7]],lookahead=barmerge.lookahead_on)
[dh8,dl8,do8,dc8] = request.security(syminfo.tickerid,"D",[high[8],low[8],open[8],close[8]],lookahead=barmerge.lookahead_on)
[dh9,dl9,do9,dc9] = request.security(syminfo.tickerid,"D",[high[9],low[9],open[9],close[9]],lookahead=barmerge.lookahead_on)
[dh10,dl10,do10,dc10] = request.security(syminfo.tickerid,"D",[high[10],low[10],open[10],close[10]],lookahead=barmerge.lookahead_on)

daily_h = array.from(dh1,dh2,dh3,dh4,dh5,dh6,dh7,dh8,dh9,dh10)
daily_l = array.from(dl1,dl2,dl3,dl4,dl5,dl6,dl7,dl8,dl9,dl10)
daily_o = array.from(do1,do2,do3,do4,do5,do6,do7,do8,do9,do10)
daily_c = array.from(dc1,dc2,dc3,dc4,dc5,dc6,dc7,dc8,dc9,dc10)

// =============================================================================
// SPACING DECAY — matches levels.py _min_spacing()
// Base spacing at PMH/PML, decays by $0.20 at max_dist
// =============================================================================
min_spacing(price) =>
    float dist = 0.0
    if not na(pmh) and price > pmh
        dist := price - pmh
    else if not na(pml) and price < pml
        dist := pml - price
    frac = math.min(dist / max_dist, 1.0)
    math.max(kl_min_space - frac * 0.20, 0.10)

// =============================================================================
// KEY LEVEL COMPUTATION — runs on last bar only
// =============================================================================
var line[]  kl_lines  = array.new_line()
var label[] kl_labels = array.new_label()

// PM level lines
var line ln_pmh = na
var line ln_pml = na
var line ln_buf_pmh_hi = na
var line ln_buf_pmh_lo = na
var line ln_buf_pml_hi = na
var line ln_buf_pml_lo = na
var label lbl_pmh = na
var label lbl_pml = na

if is_rth and pm_locked and show_pm
    if not na(ln_pmh)
        line.set_x2(ln_pmh, bar_index)
        line.set_x2(ln_pml, bar_index)
    else
        ln_pmh := line.new(bar_index, pmh, bar_index, pmh, color=col_pmh, width=pm_width, style=line.style_solid)
        ln_pml := line.new(bar_index, pml, bar_index, pml, color=col_pml, width=pm_width, style=line.style_solid)
        lbl_pmh := label.new(bar_index, pmh, "PMH " + str.tostring(pmh, format.mintick), style=label.style_none, textcolor=col_pmh, size=size.small)
        lbl_pml := label.new(bar_index, pml, "PML " + str.tostring(pml, format.mintick), style=label.style_none, textcolor=col_pml, size=size.small)
    if not na(lbl_pmh)
        label.set_x(lbl_pmh, bar_index + 3)
        label.set_x(lbl_pml, bar_index + 3)

if is_rth and pm_locked and show_buf
    if not na(ln_buf_pmh_hi)
        line.set_x2(ln_buf_pmh_hi, bar_index)
        line.set_x2(ln_buf_pmh_lo, bar_index)
        line.set_x2(ln_buf_pml_hi, bar_index)
        line.set_x2(ln_buf_pml_lo, bar_index)
    else
        ln_buf_pmh_hi := line.new(bar_index, pmh + pm_buffer, bar_index, pmh + pm_buffer, color=col_buf, width=1, style=line.style_dotted)
        ln_buf_pmh_lo := line.new(bar_index, pmh - pm_buffer, bar_index, pmh - pm_buffer, color=col_buf, width=1, style=line.style_dotted)
        ln_buf_pml_hi := line.new(bar_index, pml + pm_buffer, bar_index, pml + pm_buffer, color=col_buf, width=1, style=line.style_dotted)
        ln_buf_pml_lo := line.new(bar_index, pml - pm_buffer, bar_index, pml - pm_buffer, color=col_buf, width=1, style=line.style_dotted)

if is_rth and pm_locked and show_kl and barstate.islast
    // Clean old
    for i = 0 to array.size(kl_lines) - 1
        line.delete(array.get(kl_lines, i))
    for i = 0 to array.size(kl_labels) - 1
        label.delete(array.get(kl_labels, i))
    array.clear(kl_lines)
    array.clear(kl_labels)

    // Candidate arrays: price, priority
    var cand_price = array.new_float()
    var cand_pri   = array.new_float()
    array.clear(cand_price)
    array.clear(cand_pri)

    // ── Hourly 200 SMA — priority 50, bypasses PM buffer and distance cap ──
    sma_level = sma_200_1h
    sma_accepted_above = false
    sma_accepted_below = false
    if not na(sma_level) and sma_level > 0
        if sma_level > pmh
            sma_accepted_above := true
        else if sma_level < pml
            sma_accepted_below := true

    // ── $50 Psychological levels — priority 40 ($100 = 45) ──
    psych_start = math.floor((pml - max_dist) / 50) * 50
    psych_p = psych_start
    while psych_p <= pmh + max_dist
        if psych_p > 0
            pri = psych_p % 100 == 0 ? 45.0 : 40.0
            array.push(cand_price, psych_p)
            array.push(cand_pri, pri)
        psych_p += 50

    // ── Daily OHLC — 10 days, engine priority decay ──
    for i = 0 to 9
        d_h = array.get(daily_h, i)
        d_l = array.get(daily_l, i)
        d_o = array.get(daily_o, i)
        d_c = array.get(daily_c, i)
        day_num = i + 1  // 1-indexed to match engine
        if not na(d_h)
            float hl_pri = day_num == 1 ? 10.5 : math.max(30.0 - day_num, 5.0)
            float oc_pri = day_num == 1 ? 30.0 : math.max(10.5 - day_num * 0.5, 1.5)
            array.push(cand_price, d_h)
            array.push(cand_pri, hl_pri)
            array.push(cand_price, d_l)
            array.push(cand_pri, hl_pri)
            array.push(cand_price, d_o)
            array.push(cand_pri, oc_pri)
            array.push(cand_price, d_c)
            array.push(cand_pri, oc_pri)

    // ── $1 whole-dollar fallback — priority 5 ──
    dollar_start = math.floor(pml - max_dist)
    dollar_p = dollar_start
    while dollar_p <= pmh + max_dist
        if dollar_p > 0
            array.push(cand_price, dollar_p)
            array.push(cand_pri, 5.0)
        dollar_p += 1

    // ── Sort by priority DESC (bubble sort — Pine limitation) ──
    n_cand = array.size(cand_price)
    for i = 0 to n_cand - 2
        for j = i + 1 to n_cand - 1
            if array.get(cand_pri, j) > array.get(cand_pri, i)
                tmp_p = array.get(cand_price, i)
                tmp_r = array.get(cand_pri, i)
                array.set(cand_price, i, array.get(cand_price, j))
                array.set(cand_pri, i, array.get(cand_pri, j))
                array.set(cand_price, j, tmp_p)
                array.set(cand_pri, j, tmp_r)

    // ── Greedy selection — matches levels.py logic ──
    above = array.new_float()
    below = array.new_float()

    // ATH above: $0.50 increments from next whole dollar above PMH
    if is_ath
        float ath_start = math.ceil(pmh)
        if math.abs(ath_start - pmh) < 0.01
            ath_start += 0.50
        for i = 0 to kl_max_side - 1
            array.push(above, ath_start + i * 0.50)

    // ATL below: $0.50 decrements from next whole dollar below PML
    if is_atl
        float atl_start = math.floor(pml)
        if math.abs(atl_start - pml) < 0.01
            atl_start -= 0.50
        for i = 0 to kl_max_side - 1
            array.push(below, atl_start - i * 0.50)

    // Regular greedy selection for non-ATH/ATL sides
    accepted = array.new_float()
    for i = 0 to n_cand - 1
        price = array.get(cand_price, i)

        // Skip SMA (handled separately)
        if not na(sma_level) and math.abs(price - sma_level) < 0.01
            continue
        // Skip ATH side if ATH
        if is_ath and price > pmh
            continue
        // Skip ATL side if ATL
        if is_atl and price < pml
            continue

        // PM buffer zone check
        in_pm = price >= (pml - pm_buffer) and price <= (pmh + pm_buffer)
        if in_pm
            continue

        // Distance cap
        too_far = false
        if price > pmh and price > pmh + max_dist
            too_far := true
        if price < pml and price < pml - max_dist
            too_far := true
        if too_far
            continue

        // Spacing check against already accepted levels
        ms = min_spacing(price)
        spaced = true
        for j = 0 to array.size(accepted) - 1
            if math.abs(price - array.get(accepted, j)) < ms
                spaced := false
                break
        if spaced
            array.push(accepted, price)

    // Split accepted into above/below (only for non-ATH/ATL sides)
    if not is_ath
        count_a = 0
        for i = 0 to array.size(accepted) - 1
            p = array.get(accepted, i)
            if p > pmh and count_a < kl_max_side
                array.push(above, p)
                count_a += 1
        // Add SMA if above
        if sma_accepted_above
            array.push(above, sma_level)
        // Sort above ascending
        for i = 0 to array.size(above) - 2
            for j = i + 1 to array.size(above) - 1
                if array.get(above, j) < array.get(above, i)
                    tmp = array.get(above, i)
                    array.set(above, i, array.get(above, j))
                    array.set(above, j, tmp)

    if not is_atl
        count_b = 0
        for i = 0 to array.size(accepted) - 1
            p = array.get(accepted, i)
            if p < pml and count_b < kl_max_side
                array.push(below, p)
                count_b += 1
        // Add SMA if below
        if sma_accepted_below
            array.push(below, sma_level)
        // Sort below descending
        for i = 0 to array.size(below) - 2
            for j = i + 1 to array.size(below) - 1
                if array.get(below, j) > array.get(below, i)
                    tmp = array.get(below, i)
                    array.set(below, i, array.get(below, j))
                    array.set(below, j, tmp)

    // ── Draw levels ──
    for i = 0 to array.size(above) - 1
        lvl = array.get(above, i)
        is_sma = not na(sma_level) and math.abs(lvl - sma_level) < 0.01
        is_ath_lvl = is_ath
        c = is_sma ? col_sma : is_ath_lvl ? col_ath : col_kl
        s = is_sma ? line.style_solid : is_ath_lvl ? line.style_dotted : line.style_dashed
        ln = line.new(bar_index - 50, lvl, bar_index + 10, lvl, color=c, width=kl_width, style=s)
        array.push(kl_lines, ln)
        if show_labels
            tag = is_sma ? "200MA " : is_ath_lvl ? "ATH " : ""
            lbl = label.new(bar_index + 10, lvl, tag + str.tostring(lvl, format.mintick), style=label.style_none, textcolor=c, size=size.tiny)
            array.push(kl_labels, lbl)

    for i = 0 to array.size(below) - 1
        lvl = array.get(below, i)
        is_sma = not na(sma_level) and math.abs(lvl - sma_level) < 0.01
        is_atl_lvl = is_atl
        c = is_sma ? col_sma : is_atl_lvl ? col_ath : col_kl
        s = is_sma ? line.style_solid : is_atl_lvl ? line.style_dotted : line.style_dashed
        ln = line.new(bar_index - 50, lvl, bar_index + 10, lvl, color=c, width=kl_width, style=s)
        array.push(kl_lines, ln)
        if show_labels
            tag = is_sma ? "200MA " : is_atl_lvl ? "ATL " : ""
            lbl = label.new(bar_index + 10, lvl, tag + str.tostring(lvl, format.mintick), style=label.style_none, textcolor=c, size=size.tiny)
            array.push(kl_labels, lbl)
