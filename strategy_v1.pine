// =============================================================================
// Day Trading Strategy Indicator - v3.2
// Strategy: Levels + Trend + Patience Candle
// Timeframes: 2min (first 30m) | 5min (next 60m) | 10min (remainder)
// NOTE: S/R levels are drawn manually on the hourly chart before market open.
// =============================================================================
//@version=6
indicator("Day Trading Strategy v1", overlay=true, max_lines_count=500, max_labels_count=500, max_polylines_count=100)

// =============================================================================
// INPUTS — MOVING AVERAGES
// =============================================================================
grp_sma = "Moving Averages"

show_8       = input.bool(true,          "Show 8 SMA",          inline="8",   group=grp_sma)
col_8        = input.color(color.blue,   "",                    inline="8",   group=grp_sma)
width_8      = input.int(1, "",          minval=1, maxval=4,    inline="8",   group=grp_sma)

show_21      = input.bool(true,          "Show 21 SMA",         inline="21",  group=grp_sma)
col_21       = input.color(color.purple, "",                    inline="21",  group=grp_sma)
width_21     = input.int(2, "",          minval=1, maxval=4,    inline="21",  group=grp_sma)

show_200_5m  = input.bool(true,          "Show 5min 200 SMA",   inline="5m",  group=grp_sma)
col_200_5m   = input.color(color.orange, "",                    inline="5m",  group=grp_sma)
width_200_5m = input.int(2, "",          minval=1, maxval=4,    inline="5m",  group=grp_sma)

show_200_10m = input.bool(true,          "Show 10min 200 SMA",  inline="10m", group=grp_sma)
col_200_10m  = input.color(color.yellow, "",                    inline="10m", group=grp_sma)
width_200_10m= input.int(2, "",          minval=1, maxval=4,    inline="10m", group=grp_sma)

show_200_1h  = input.bool(true,          "Show Hourly 200 SMA", inline="1h",  group=grp_sma)
col_200_1h   = input.color(color.red,    "",                    inline="1h",  group=grp_sma)
width_200_1h = input.int(2, "",          minval=1, maxval=4,    inline="1h",  group=grp_sma)

// =============================================================================
// INPUTS — VWAP
// =============================================================================
grp_vwap   = "VWAP"
show_vwap  = input.bool(true,         "Show VWAP", inline="vwap", group=grp_vwap)
col_vwap   = input.color(color.teal,  "",          inline="vwap", group=grp_vwap)
width_vwap = input.int(2, "",         minval=1, maxval=4, inline="vwap", group=grp_vwap)

// =============================================================================
// INPUTS — PRE-MARKET LEVELS
// =============================================================================
grp_pm   = "Pre-Market Levels"
show_pm  = input.bool(true,         "Show PMH / PML (last 5 days)", group=grp_pm)
col_pm   = input.color(color.white, "Line color",                   group=grp_pm)

// =============================================================================
// INPUTS — OPENING RANGE
// =============================================================================
grp_or  = "Opening Range"
show_or = input.bool(true, "Show Opening Range (9:30–9:45)", group=grp_or)

// =============================================================================
// INPUTS — PATIENCE CANDLE
// =============================================================================
grp_pc   = "Patience Candle"
show_pc  = input.bool(true, "Show Patience Candle Arrows", group=grp_pc)

// =============================================================================
// MOVING AVERAGES
// =============================================================================
sma8       = ta.sma(close, 8)
sma21      = ta.sma(close, 21)
sma200_5m  = request.security(syminfo.tickerid, "5",  ta.sma(close, 200))
sma200_10m = request.security(syminfo.tickerid, "10", ta.sma(close, 200))
sma200_1h  = request.security(syminfo.tickerid, "60", ta.sma(close, 200))

plot(show_8       ? sma8       : na, "8 SMA",          color=col_8,        linewidth=width_8)
plot(show_21      ? sma21      : na, "21 SMA",         color=col_21,       linewidth=width_21)
plot(show_200_5m  ? sma200_5m  : na, "5min 200 SMA",   color=col_200_5m,   linewidth=width_200_5m)
plot(show_200_10m ? sma200_10m : na, "10min 200 SMA",  color=col_200_10m,  linewidth=width_200_10m)
plot(show_200_1h  ? sma200_1h  : na, "Hourly 200 SMA", color=col_200_1h,   linewidth=width_200_1h)

// =============================================================================
// VWAP
// =============================================================================
vwap_val = ta.vwap(hlc3)
plot(show_vwap ? vwap_val : na, "VWAP", color=col_vwap, linewidth=width_vwap)

// =============================================================================
// SESSION DETECTION
// =============================================================================
bool is_premarket = session.ispremarket
bool is_regular   = session.ismarket
bool session_open = is_regular and not is_regular[1]

// =============================================================================
// TIME OF DAY (ET)
// =============================================================================
int et_hour   = hour(time, "America/New_York")
int et_minute = minute(time, "America/New_York")

bool in_or         = is_regular and et_hour == 9 and et_minute < 45
bool or_just_ended = is_regular and not in_or and in_or[1]
bool in_last_hour  = is_regular and et_hour >= 15

// =============================================================================
// PRE-MARKET HIGH / LOW — last 5 trading days, scoped per day
// =============================================================================
var float pm_high        = na
var float pm_low         = na
var float pm_high_locked = na
var float pm_low_locked  = na
var bool  pm_locked      = false

if session_open
    pm_high_locked := pm_high
    pm_low_locked  := pm_low
    pm_high        := na
    pm_low         := na
    pm_locked      := true

if is_premarket
    pm_high   := na(pm_high) ? high : math.max(pm_high, high)
    pm_low    := na(pm_low)  ? low  : math.min(pm_low,  low)
    pm_locked := false

float pmh = pm_locked ? pm_high_locked : pm_high
float pml = pm_locked ? pm_low_locked  : pm_low

var line[]  pmh_lines  = array.new<line>()
var line[]  pml_lines  = array.new<line>()
var label[] pmh_labels = array.new<label>()
var label[] pml_labels = array.new<label>()
var line    pmh_cur    = na
var line    pml_cur    = na

if show_pm and session_open and not na(pmh) and not na(pml)
    line new_pmh = line.new(bar_index, pmh, bar_index + 1, pmh, color=col_pm, width=1, style=line.style_solid)
    line new_pml = line.new(bar_index, pml, bar_index + 1, pml, color=col_pm, width=1, style=line.style_solid)
    array.push(pmh_lines, new_pmh)
    array.push(pml_lines, new_pml)
    pmh_cur := new_pmh
    pml_cur := new_pml

    label lh = label.new(bar_index, pmh, "PMH " + str.tostring(pmh, "#.##"),
         color=color.new(color.white, 100), textcolor=col_pm, size=size.small, style=label.style_label_right)
    label ll = label.new(bar_index, pml, "PML " + str.tostring(pml, "#.##"),
         color=color.new(color.white, 100), textcolor=col_pm, size=size.small, style=label.style_label_right)
    array.push(pmh_labels, lh)
    array.push(pml_labels, ll)

    while array.size(pmh_lines) > 5
        line.delete(array.shift(pmh_lines))
        line.delete(array.shift(pml_lines))
        label.delete(array.shift(pmh_labels))
        label.delete(array.shift(pml_labels))

if show_pm and is_regular and not na(pmh_cur)
    line.set_x2(pmh_cur, bar_index)
    line.set_x2(pml_cur, bar_index)

// =============================================================================
// OPENING RANGE HIGH / LOW — drawn at 9:45, extends 4 bars right
// =============================================================================
var float or_high = na
var float or_low  = na

if session_open
    or_high := na
    or_low  := na

if in_or
    or_high := na(or_high) ? high : math.max(or_high, high)
    or_low  := na(or_low)  ? low  : math.min(or_low,  low)

if show_or and or_just_ended and not na(or_high)
    line.new(bar_index, or_high, bar_index + 4, or_high, color=color.lime, width=2, style=line.style_solid)
    line.new(bar_index, or_low,  bar_index + 4, or_low,  color=color.lime, width=2, style=line.style_solid)

// =============================================================================
// TREND DIRECTION
// Uses PMH/PML when available. Falls back to session open price when
// pre-market data is not present on the chart.
// =============================================================================
var float sess_open_price = na
if session_open
    sess_open_price := open

float ref_high = na(pmh) ? sess_open_price : pmh
float ref_low  = na(pml) ? sess_open_price : pml

bool above_ref = not na(ref_high) and close > ref_high
bool below_ref = not na(ref_low)  and close < ref_low

bool above_pm = not na(pmh) and close > pmh
bool below_pm = not na(pml) and close < pml

var int trend_dir = 0  // 1 = long | -1 = short | 0 = no trend yet
if session_open
    trend_dir := 0
if above_ref and trend_dir == 0
    trend_dir := 1
if below_ref and trend_dir == 0
    trend_dir := -1

// =============================================================================
// PATIENCE CANDLE DETECTION
//
// Long:  in uptrend, current bar's high did NOT break the previous bar's high
// Short: in downtrend, current bar's low did NOT break the previous bar's low
//
// Filters:
//   - Entry must be outside PM zone
//   - No PCs in the last hour (3:00 PM ET onward)
// =============================================================================
bool valid_tf = timeframe.period == "2" or timeframe.period == "5" or timeframe.period == "10"

bool pc_long_valid  = is_regular and valid_tf and trend_dir == 1
     and high <  high[1] and high > ref_high
     and not in_last_hour

bool pc_short_valid = is_regular and valid_tf and trend_dir == -1
     and low  >  low[1]  and low  < ref_low
     and not in_last_hour

bool pc_long_done  = is_regular and valid_tf and trend_dir == 1  and high >= high[1]
bool pc_short_done = is_regular and valid_tf and trend_dir == -1 and low  <= low[1]

float atr_val = ta.atr(14)
float tri_h   = atr_val * 0.90
float tri_gap = atr_val * 0.15

var polyline pc_poly = na

if session_open
    polyline.delete(pc_poly)
    pc_poly := na

if pc_long_done or pc_short_done
    pc_poly := na

if show_pc and pc_long_valid
    polyline.delete(pc_poly)
    pc_poly := polyline.new(
         array.from(
             chart.point.from_index(bar_index,     low - tri_gap),
             chart.point.from_index(bar_index - 1, low - tri_gap - tri_h),
             chart.point.from_index(bar_index + 1, low - tri_gap - tri_h)),
         closed=true,
         fill_color=color.new(color.green, 0),
         line_color=color.new(color.green, 0))

else if show_pc and pc_short_valid
    polyline.delete(pc_poly)
    pc_poly := polyline.new(
         array.from(
             chart.point.from_index(bar_index,     high + tri_gap),
             chart.point.from_index(bar_index - 1, high + tri_gap + tri_h),
             chart.point.from_index(bar_index + 1, high + tri_gap + tri_h)),
         closed=true,
         fill_color=color.new(color.red, 0),
         line_color=color.new(color.red, 0))

// =============================================================================
// ALERTS
// =============================================================================
alertcondition(pc_long_valid  and not pc_long_valid[1],
     "Patience Candle - LONG",
     "Long patience candle. Entry above PC high, stop below PC low.")

alertcondition(pc_short_valid and not pc_short_valid[1],
     "Patience Candle - SHORT",
     "Short patience candle. Entry below PC low, stop above PC high.")

alertcondition(above_pm and not above_pm[1],
     "PM Breakout - LONG",  "Price broke above pre-market high.")

alertcondition(below_pm and not below_pm[1],
     "PM Breakout - SHORT", "Price broke below pre-market low.")
