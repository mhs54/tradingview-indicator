// =============================================================================
// Day Trading Strategy Indicator - v1.6
// Strategy: Levels + Trend + Patience Candle
// Timeframes: 2min (first 30m) | 5min (next 60m) | 10min (remainder)
// NOTE: S/R levels are drawn manually on the hourly chart before market open.
// =============================================================================
//@version=6
indicator("Day Trading Strategy v1", overlay=true, max_lines_count=500, max_labels_count=500)

// =============================================================================
// INPUTS — MOVING AVERAGES
// =============================================================================
grp_sma = "Moving Averages"

show_8       = input.bool(true,          "Show 8 SMA",          inline="8",   group=grp_sma)
col_8        = input.color(color.blue,   "",                    inline="8",   group=grp_sma)
width_8      = input.int(1, "",          minval=1, maxval=4,    inline="8",   group=grp_sma)

show_21      = input.bool(true,          "Show 21 SMA",         inline="21",  group=grp_sma)
col_21       = input.color(color.purple, "",                    inline="21",  group=grp_sma)
width_21     = input.int(2, "",          minval=1, maxval=4,    inline="21",  group=grp_sma)

show_200_5m  = input.bool(true,          "Show 5min 200 SMA",   inline="5m",  group=grp_sma)
col_200_5m   = input.color(color.orange, "",                    inline="5m",  group=grp_sma)
width_200_5m = input.int(2, "",          minval=1, maxval=4,    inline="5m",  group=grp_sma)

show_200_10m = input.bool(true,          "Show 10min 200 SMA",  inline="10m", group=grp_sma)
col_200_10m  = input.color(color.yellow, "",                    inline="10m", group=grp_sma)
width_200_10m= input.int(2, "",          minval=1, maxval=4,    inline="10m", group=grp_sma)

show_200_1h  = input.bool(true,          "Show Hourly 200 SMA", inline="1h",  group=grp_sma)
col_200_1h   = input.color(color.red,    "",                    inline="1h",  group=grp_sma)
width_200_1h = input.int(2, "",          minval=1, maxval=4,    inline="1h",  group=grp_sma)

// =============================================================================
// INPUTS — VWAP
// =============================================================================
grp_vwap   = "VWAP"
show_vwap  = input.bool(true,         "Show VWAP", inline="vwap", group=grp_vwap)
col_vwap   = input.color(color.teal,  "",          inline="vwap", group=grp_vwap)
width_vwap = input.int(2, "",         minval=1, maxval=4, inline="vwap", group=grp_vwap)

// =============================================================================
// INPUTS — PRE-MARKET LEVELS
// =============================================================================
grp_pm   = "Pre-Market Levels"
show_pm  = input.bool(true,         "Show PMH / PML (last 5 days)", group=grp_pm)
col_pm   = input.color(color.white, "Line color",                   group=grp_pm)

// =============================================================================
// INPUTS — PATIENCE CANDLE
// =============================================================================
grp_pc      = "Patience Candle"
show_pc     = input.bool(true,  "Show Patience Candle Arrows",              group=grp_pc)
retrace_pct = input.float(40.0, "Daily range retracement % to suppress",
              minval=10, maxval=60, step=5,                                  group=grp_pc)

// =============================================================================
// MOVING AVERAGES
// =============================================================================
sma8       = ta.sma(close, 8)
sma21      = ta.sma(close, 21)
sma200_5m  = request.security(syminfo.tickerid, "5",  ta.sma(close, 200))
sma200_10m = request.security(syminfo.tickerid, "10", ta.sma(close, 200))
sma200_1h  = request.security(syminfo.tickerid, "60", ta.sma(close, 200))

plot(show_8       ? sma8       : na, "8 SMA",          color=col_8,        linewidth=width_8)
plot(show_21      ? sma21      : na, "21 SMA",         color=col_21,       linewidth=width_21)
plot(show_200_5m  ? sma200_5m  : na, "5min 200 SMA",   color=col_200_5m,   linewidth=width_200_5m)
plot(show_200_10m ? sma200_10m : na, "10min 200 SMA",  color=col_200_10m,  linewidth=width_200_10m)
plot(show_200_1h  ? sma200_1h  : na, "Hourly 200 SMA", color=col_200_1h,   linewidth=width_200_1h)

// =============================================================================
// VWAP
// =============================================================================
vwap_val = ta.vwap(hlc3)
plot(show_vwap ? vwap_val : na, "VWAP", color=col_vwap, linewidth=width_vwap)

// =============================================================================
// SESSION DETECTION
// =============================================================================
is_premarket = not na(time("1", "0400-0930:23456"))
is_regular   = not na(time("1", "0930-1600:23456"))
session_open = not na(time("1", "0930-0931:23456"))

// =============================================================================
// PRE-MARKET HIGH / LOW — last 5 trading days, scoped per day
// =============================================================================
var float pm_high        = na
var float pm_low         = na
var float pm_high_locked = na
var float pm_low_locked  = na
var bool  pm_locked      = false

if session_open and not session_open[1]
    pm_high_locked := pm_high
    pm_low_locked  := pm_low
    pm_high        := na
    pm_low         := na
    pm_locked      := true

if is_premarket
    pm_high   := na(pm_high) ? high : math.max(pm_high, high)
    pm_low    := na(pm_low)  ? low  : math.min(pm_low,  low)
    pm_locked := false

float pmh = pm_locked ? pm_high_locked : pm_high
float pml = pm_locked ? pm_low_locked  : pm_low

var line[]  pmh_lines  = array.new<line>()
var line[]  pml_lines  = array.new<line>()
var label[] pmh_labels = array.new<label>()
var label[] pml_labels = array.new<label>()
var line    pmh_cur    = na
var line    pml_cur    = na

if show_pm and session_open
    line new_pmh = line.new(bar_index, pmh, bar_index + 1, pmh, color=col_pm, width=1, style=line.style_solid)
    line new_pml = line.new(bar_index, pml, bar_index + 1, pml, color=col_pm, width=1, style=line.style_solid)
    array.push(pmh_lines, new_pmh)
    array.push(pml_lines, new_pml)
    pmh_cur := new_pmh
    pml_cur := new_pml

    label lh = label.new(bar_index, pmh, "PMH " + str.tostring(pmh, "#.##"),
         color=color.new(color.white, 100), textcolor=col_pm, size=size.small, style=label.style_label_right)
    label ll = label.new(bar_index, pml, "PML " + str.tostring(pml, "#.##"),
         color=color.new(color.white, 100), textcolor=col_pm, size=size.small, style=label.style_label_right)
    array.push(pmh_labels, lh)
    array.push(pml_labels, ll)

    while array.size(pmh_lines) > 5
        line.delete(array.shift(pmh_lines))
        line.delete(array.shift(pml_lines))
        label.delete(array.shift(pmh_labels))
        label.delete(array.shift(pml_labels))

if show_pm and is_regular and not na(pmh_cur)
    line.set_x2(pmh_cur, bar_index)
    line.set_x2(pml_cur, bar_index)

// =============================================================================
// TREND DIRECTION (PM breakout)
// =============================================================================
bool above_pm = not na(pmh) and close > pmh
bool below_pm = not na(pml) and close < pml

var int trend_dir = 0  // 1 = long | -1 = short | 0 = inside range
if session_open
    trend_dir := 0
if above_pm and trend_dir == 0
    trend_dir := 1
if below_pm and trend_dir == 0
    trend_dir := -1

// =============================================================================
// SESSION HIGH / LOW TRACKING
// Tracks the running high and low since market open.
// Used for retracement suppression and PC containment checks.
// =============================================================================
var float day_high = na
var float day_low  = na

if session_open
    day_high := na
    day_low  := na

// Capture previous values before update (to detect new session highs/lows)
float prev_day_high = day_high
float prev_day_low  = day_low

if is_regular
    day_high := na(day_high) ? high : math.max(day_high, high)
    day_low  := na(day_low)  ? low  : math.min(day_low,  low)

// New session high/low: current bar exceeded what was previously the day extreme
bool new_sess_high = is_regular and trend_dir == 1  and high > nz(prev_day_high, high - 1)
bool new_sess_low  = is_regular and trend_dir == -1 and low  < nz(prev_day_low,  low  + 1)

// =============================================================================
// 40% DAILY RANGE RETRACEMENT SUPPRESSION
// Based on the full daily range (day_high - day_low), not the move from PMH.
// Example: if day_high=$14, day_low=$8, range=$6, 40% threshold=$2.40
// Suppress longs if price drops $2.40 from day_high (to $11.60 or below).
// Reset suppression when a new session high (long) or low (short) is made.
// =============================================================================
var bool long_suppressed  = false
var bool short_suppressed = false

if session_open
    long_suppressed  := false
    short_suppressed := false

float daily_range     = not na(day_high) and not na(day_low) ? day_high - day_low : 0.0
float retrace_thresh  = retrace_pct / 100.0

if is_regular and trend_dir == 1 and daily_range > 0
    if new_sess_high
        long_suppressed := false  // new high resets suppression
    else if low <= day_high - daily_range * retrace_thresh
        long_suppressed := true

if is_regular and trend_dir == -1 and daily_range > 0
    if new_sess_low
        short_suppressed := false  // new low resets suppression
    else if high >= day_low + daily_range * retrace_thresh
        short_suppressed := true

// =============================================================================
// PATIENCE CANDLE DETECTION
//
// A patience candle (PC) is a pullback candle that is "contained":
//   Long:  high < day_high (didn't make new session high)
//          AND high <= high[1] (didn't exceed the previous bar's high)
//   Short: low > day_low (didn't make new session low)
//          AND low >= low[1] (didn't undercut the previous bar's low)
//
// Only the MOST RECENT PC gets an arrow. When a new PC forms, the previous
// arrow is deleted and replaced. When entry is triggered (next bar breaks
// above PC high for long / below PC low for short), the arrow is cleared.
//
// Arrows only show on 2, 5, and 10 minute charts.
// =============================================================================
bool valid_tf = timeframe.period == "2" or timeframe.period == "5" or timeframe.period == "10"

bool is_pc_long = is_regular
     and valid_tf
     and trend_dir == 1
     and not na(pmh) and close > pmh
     and not long_suppressed
     and not na(day_high)
     and high < day_high      // contained: didn't make new session high
     and high <= high[1]      // contained: didn't exceed previous bar's high

bool is_pc_short = is_regular
     and valid_tf
     and trend_dir == -1
     and not na(pml) and close < pml
     and not short_suppressed
     and not na(day_low)
     and low > day_low        // contained: didn't make new session low
     and low >= low[1]        // contained: didn't undercut previous bar's low

// Active PC state
var label pc_label  = na
var float pc_entry  = na  // price level that triggers entry (PC high for long, PC low for short)
var bool  pc_is_long = true

// --- Clear active PC when: ---
// 1. Entry triggered: next bar broke above PC high (long) or below PC low (short)
bool entry_triggered = not na(pc_entry) and
     ((pc_is_long and high > pc_entry) or (not pc_is_long and low < pc_entry))

// 2. New session high/low made (trend bar, not a pullback)
// 3. Suppression kicked in
// 4. Session ended
bool clear_pc = entry_triggered or new_sess_high or new_sess_low
     or (trend_dir == 1 and long_suppressed)
     or (trend_dir == -1 and short_suppressed)
     or session_open

if clear_pc
    label.delete(pc_label)
    pc_label := na
    pc_entry := na

// --- Create / refresh PC arrow ---
if show_pc and is_pc_long
    label.delete(pc_label)
    pc_label   := label.new(bar_index, low, "",
         style=label.style_arrowup, yloc=yloc.belowbar,
         color=color.new(color.green, 0), size=size.normal)
    pc_entry   := high
    pc_is_long := true

else if show_pc and is_pc_short
    label.delete(pc_label)
    pc_label   := label.new(bar_index, high, "",
         style=label.style_arrowdown, yloc=yloc.abovebar,
         color=color.new(color.red, 0), size=size.normal)
    pc_entry   := low
    pc_is_long := false

// =============================================================================
// ALERTS
// =============================================================================
alertcondition(is_pc_long  and not is_pc_long[1],
     "Patience Candle - LONG",
     "Long patience candle forming. Entry above PC high, stop below PC low.")

alertcondition(is_pc_short and not is_pc_short[1],
     "Patience Candle - SHORT",
     "Short patience candle forming. Entry below PC low, stop above PC high.")

alertcondition(above_pm and not above_pm[1],
     "PM Breakout - LONG",
     "Price broke above pre-market high.")

alertcondition(below_pm and not below_pm[1],
     "PM Breakout - SHORT",
     "Price broke below pre-market low.")
