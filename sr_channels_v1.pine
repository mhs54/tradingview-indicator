// Based on "Support Resistance Channels" by LonesomeTheBlue
// Modified: yellow boundary lines, hourly pivots, time-based loopback, dynamic levels
//@version=6
indicator('SR Channels (Hourly)', 'SRchannel', overlay = true, max_bars_back = 501, max_lines_count = 500)

prd           = input.int(10,  'Pivot Period',            minval = 4,   maxval = 30,  group = 'Settings')
ppsrc         = input.string('High/Low', 'Source',        options = ['High/Low', 'Close/Open'], group = 'Settings')
ChannelW      = input.int(5,   'Maximum Channel Width %', minval = 1,   maxval = 8,   group = 'Settings')
minstrength   = input.int(1,   'Minimum Strength',        minval = 1,                 group = 'Settings')
loopback_days = input.int(60,  'Loopback Period (Days)',  minval = 5,   maxval = 365, group = 'Settings')

// Pivot source — calculated on the hourly chart
float src1 = ppsrc == 'High/Low' ? high : math.max(close, open)
float src2 = ppsrc == 'High/Low' ? low  : math.min(close, open)

float ph = request.security(syminfo.tickerid, '60', ta.pivothigh(src1, prd, prd))
float pl = request.security(syminfo.tickerid, '60', ta.pivotlow(src2,  prd, prd))

// Channel width based on hourly range
float prdhighest = request.security(syminfo.tickerid, '60', ta.highest(300))
float prdlowest  = request.security(syminfo.tickerid, '60', ta.lowest(300))
float cwidth     = (prdhighest - prdlowest) * ChannelW / 100

// Pre-market high/low for current trading day
int  et_hour      = hour(time, 'America/New_York')
int  et_minute    = minute(time, 'America/New_York')
bool is_regular   = session.ismarket
bool session_open = is_regular and not is_regular[1]
bool in_premarket = not is_regular and et_hour >= 4 and (et_hour < 9 or (et_hour == 9 and et_minute < 30))

var float pm_build_h = na
var float pm_build_l = na
var float pmh_day    = na
var float pml_day    = na

// Cutoff = 4:00 AM ET today (9:30 AM regular open minus 5.5 hours)
// Pivots at or after this time are from the current trading day and are excluded
var float today_cutoff = na
if session_open
    today_cutoff := time - int(5.5 * 3600000)
    pmh_day    := pm_build_h
    pml_day    := pm_build_l
    pm_build_h := na
    pm_build_l := na

if in_premarket
    pm_build_h := na(pm_build_h) ? high : math.max(pm_build_h, high)
    pm_build_l := na(pm_build_l) ? low  : math.min(pm_build_l, low)

// Collect pivot values (cap at 100 for performance)
// Exclude any pivot from the current trading day (on or after 4 AM ET today)
var pivotvals = array.new_float(0)
var pivotlocs = array.new_float(0)

bool pivot_from_prior_day = na(today_cutoff) or time < today_cutoff
if (bool(ph) or bool(pl)) and pivot_from_prior_day
    array.unshift(pivotvals, bool(ph) ? ph : pl)
    array.unshift(pivotlocs, time)
    // Prune pivots older than loopback_days
    int sz = array.size(pivotvals)
    while sz > 0
        if time - array.get(pivotlocs, sz - 1) > loopback_days * 86400000
            array.pop(pivotvals)
            array.pop(pivotlocs)
            sz -= 1
        else
            break
    // Cap size for performance
    while array.size(pivotvals) > 100
        array.pop(pivotvals)
        array.pop(pivotlocs)

// Build SR channel for a given pivot
get_sr_vals(ind) =>
    float lo = array.get(pivotvals, ind)
    float hi = lo
    int numpp = 0
    for y = 0 to array.size(pivotvals) - 1 by 1
        float cpp = array.get(pivotvals, y)
        float wdth = cpp <= hi ? hi - cpp : cpp - lo
        if wdth <= cwidth
            if cpp <= hi
                lo := math.min(lo, cpp)
            else
                hi := math.max(hi, cpp)
            numpp := numpp + 20
    [hi, lo, numpp]

var suportresistance = array.new_float(20, 0)

changeit(x, y) =>
    tmp = array.get(suportresistance, y * 2)
    array.set(suportresistance, y * 2, array.get(suportresistance, x * 2))
    array.set(suportresistance, x * 2, tmp)
    tmp := array.get(suportresistance, y * 2 + 1)
    array.set(suportresistance, y * 2 + 1, array.get(suportresistance, x * 2 + 1))
    array.set(suportresistance, x * 2 + 1, tmp)

if (bool(ph) or bool(pl)) and array.size(pivotvals) > 0
    supres = array.new_float(0)
    stren  = array.new_float(10, 0)
    int npv = array.size(pivotvals)

    for x = 0 to npv - 1 by 1
        [hi, lo, strength] = get_sr_vals(x)
        array.push(supres, strength)
        array.push(supres, hi)
        array.push(supres, lo)

    // Count how many recent bars touch each level (capped at 100 for performance)
    for x = 0 to npv - 1 by 1
        float h = array.get(supres, x * 3 + 1)
        float l = array.get(supres, x * 3 + 2)
        int s = 0
        for y = 0 to math.min(100, bar_index) by 1
            if high[y] <= h and high[y] >= l or low[y] <= h and low[y] >= l
                s := s + 1
        array.set(supres, x * 3, array.get(supres, x * 3) + s)

    array.fill(suportresistance, 0)
    int src = 0
    for x = 0 to npv - 1 by 1
        float stv = -1.
        int stl = -1
        for y = 0 to npv - 1 by 1
            if array.get(supres, y * 3) > stv and array.get(supres, y * 3) >= minstrength * 20
                stv := array.get(supres, y * 3)
                stl := y
        if stl >= 0
            float hh = array.get(supres, stl * 3 + 1)
            float ll = array.get(supres, stl * 3 + 2)
            array.set(suportresistance, src * 2,     hh)
            array.set(suportresistance, src * 2 + 1, ll)
            array.set(stren, src, array.get(supres, stl * 3))
            for y = 0 to npv - 1 by 1
                if array.get(supres, y * 3 + 1) <= hh and array.get(supres, y * 3 + 1) >= ll or array.get(supres, y * 3 + 2) <= hh and array.get(supres, y * 3 + 2) >= ll
                    array.set(supres, y * 3, -1)
            src := src + 1
            if src >= 10
                break

    for x = 0 to 8 by 1
        for y = x + 1 to 9 by 1
            if array.get(stren, y) > array.get(stren, x)
                float tmp = array.get(stren, y)
                array.set(stren, y, array.get(stren, x))
                array.set(stren, x, tmp)
                changeit(x, y)

get_level(ind) =>
    float ret = na
    if ind < array.size(suportresistance)
        if array.get(suportresistance, ind) != 0
            ret := array.get(suportresistance, ind)
    ret

// Dynamic level selection based on price vs PM zone
bool has_pm      = not na(pmh_day) and not na(pml_day)
bool above_pm    = has_pm and close > pmh_day
bool below_pm    = has_pm and close < pml_day

// How many levels to show in each direction
int n_above = above_pm ? 3 : 2
int n_below = below_pm ? 3 : 2

// Split all 10 SR levels into above/below price, excluding levels inside PM zone
var above_tops = array.new_float(0)
var above_bots = array.new_float(0)
var below_tops = array.new_float(0)
var below_bots = array.new_float(0)

array.clear(above_tops)
array.clear(above_bots)
array.clear(below_tops)
array.clear(below_bots)

for x = 0 to 9 by 1
    float top_lvl = get_level(x * 2)
    float bot_lvl = get_level(x * 2 + 1)
    if not na(top_lvl) and not na(bot_lvl)
        // Skip levels whose channel is entirely inside the PM zone
        bool in_pm = has_pm and bot_lvl >= pml_day and top_lvl <= pmh_day
        if not in_pm
            float mid = (top_lvl + bot_lvl) / 2
            if mid >= close
                array.push(above_tops, top_lvl)
                array.push(above_bots, bot_lvl)
            else
                array.push(below_tops, top_lvl)
                array.push(below_bots, bot_lvl)

// Bubble-sort above levels ascending by bot (closest to price first)
int above_sz = array.size(above_bots)
if above_sz >= 2
    for i = 0 to above_sz - 2 by 1
        for j = 0 to above_sz - 2 - i by 1
            if array.get(above_bots, j) > array.get(above_bots, j + 1)
                float tmp_t = array.get(above_tops, j)
                float tmp_b = array.get(above_bots, j)
                array.set(above_tops, j, array.get(above_tops, j + 1))
                array.set(above_bots, j, array.get(above_bots, j + 1))
                array.set(above_tops, j + 1, tmp_t)
                array.set(above_bots, j + 1, tmp_b)

// Bubble-sort below levels descending by top (closest to price first)
int below_sz = array.size(below_tops)
if below_sz >= 2
    for i = 0 to below_sz - 2 by 1
        for j = 0 to below_sz - 2 - i by 1
            if array.get(below_tops, j) < array.get(below_tops, j + 1)
                float tmp_t = array.get(below_tops, j)
                float tmp_b = array.get(below_bots, j)
                array.set(below_tops, j, array.get(below_tops, j + 1))
                array.set(below_bots, j, array.get(below_bots, j + 1))
                array.set(below_tops, j + 1, tmp_t)
                array.set(below_bots, j + 1, tmp_b)

// Delete all existing lines and redraw
var sr_top = array.new_line(10)
var sr_bot = array.new_line(10)

for x = 0 to 9 by 1
    line.delete(array.get(sr_top, x))
    line.delete(array.get(sr_bot, x))
    array.set(sr_top, x, na)
    array.set(sr_bot, x, na)

int slot = 0
int draw_above = math.min(n_above, array.size(above_tops))
int draw_below = math.min(n_below, array.size(below_tops))

if draw_above > 0
    for x = 0 to draw_above - 1 by 1
        if slot < 10
            array.set(sr_top, slot, line.new(bar_index, array.get(above_tops, x), bar_index + 1, array.get(above_tops, x),
                 extend = extend.both, color = color.yellow, width = 1, style = line.style_solid))
            array.set(sr_bot, slot, line.new(bar_index, array.get(above_bots, x), bar_index + 1, array.get(above_bots, x),
                 extend = extend.both, color = color.yellow, width = 1, style = line.style_solid))
            slot += 1

if draw_below > 0
    for x = 0 to draw_below - 1 by 1
        if slot < 10
            array.set(sr_top, slot, line.new(bar_index, array.get(below_tops, x), bar_index + 1, array.get(below_tops, x),
                 extend = extend.both, color = color.yellow, width = 1, style = line.style_solid))
            array.set(sr_bot, slot, line.new(bar_index, array.get(below_bots, x), bar_index + 1, array.get(below_bots, x),
                 extend = extend.both, color = color.yellow, width = 1, style = line.style_solid))
            slot += 1

// Alerts
bool resistancebroken = false
bool supportbroken    = false
bool not_in_a_channel = true

for x = 0 to 9 by 1
    if close <= array.get(suportresistance, x * 2) and close >= array.get(suportresistance, x * 2 + 1)
        not_in_a_channel := false

if not_in_a_channel
    for x = 0 to 9 by 1
        if close[1] <= array.get(suportresistance, x * 2) and close > array.get(suportresistance, x * 2)
            resistancebroken := true
        if close[1] >= array.get(suportresistance, x * 2 + 1) and close < array.get(suportresistance, x * 2 + 1)
            supportbroken := true

alertcondition(resistancebroken, title = 'Resistance Broken', message = 'Resistance Broken')
alertcondition(supportbroken,    title = 'Support Broken',    message = 'Support Broken')
