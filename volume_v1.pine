// =============================================================================
// Volume Indicator - v1.0
// Add to chart then use "Move to existing pane" to merge into price chart pane.
// =============================================================================
//@version=6
indicator("Volume", overlay=false)

ma_len = input.int(10, "MA Length", minval=1)

vol_color = close >= open ? color.new(color.green, 60) : color.new(color.red, 60)

plot(volume * 0.4, "Volume", color=vol_color, style=plot.style_columns)
plot(ta.sma(volume, ma_len), "Vol MA", color=color.yellow, linewidth=2)
