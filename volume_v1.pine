// =============================================================================
// Volume Indicator - v1.0
// Carbon copy of standard volume with bars scaled 10% larger
// + solid yellow 10-period MA line
// Add this as a SEPARATE indicator in a new pane below the main chart.
// =============================================================================
//@version=6
indicator("Volume", overlay=false)

ma_len = input.int(10, "Volume MA Length", minval=1)

// Scale volume 10% larger so bars are visually taller and easier to read
vol_display = volume * 1.1

// Green if close >= open (up bar), red if close < open (down bar)
vol_color = close >= open ? color.new(color.green, 20) : color.new(color.red, 20)

plot(vol_display, "Volume", color=vol_color, style=plot.style_columns)

// 10-period MA on actual volume (not scaled), displayed as solid yellow line
vol_ma = ta.sma(volume, ma_len)
plot(vol_ma, "Vol MA", color=color.yellow, linewidth=2)
