// =============================================================================
// Volume Indicator — standalone pane
// =============================================================================
//@version=6
indicator("Volume", overlay=false)

ma_len       = input.int(10,  "MA Length",              minval=1)
vol_lookback = input.int(100, "Normalization Lookback",  minval=10)

// Normalize bars to 0-100 so height is consistent across all timeframes
vol_max      = ta.highest(volume, vol_lookback)
float norm   = vol_max > 0 ? 100.0 / vol_max : 0.0

vol_up_col   = color.new(color.green, 30)
vol_down_col = color.new(color.red,   30)
vol_color    = close >= open ? vol_up_col : vol_down_col

// Floor at 0 — no negative scale
hline(0, color=color.new(color.white, 100), linewidth=1)

plot(volume * norm,                 "Volume", color=vol_color,    style=plot.style_columns)
plot(ta.sma(volume, ma_len) * norm, "Vol MA", color=color.yellow, linewidth=2)
