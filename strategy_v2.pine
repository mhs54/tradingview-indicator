// =============================================================================
// Day Trading Strategy Indicator - v2.0
// Combines: Strategy (VWAP, SMAs, PM levels, ORB, Patience Candle)
//         + SR Channels (hourly pivot-based support/resistance)
// Strategy: Levels + Trend + Patience Candle
// Timeframes: 2min (first 30m) | 5min (next 60m) | 10min (remainder)
// =============================================================================
//@version=6
indicator("Day Trading Strategy v2", overlay=true, max_bars_back=501, max_lines_count=500, max_labels_count=500, max_polylines_count=100)

// =============================================================================
// INPUTS — MOVING AVERAGES
// =============================================================================
grp_sma = "Moving Averages"

show_8        = input.bool(true,          "Show 8 SMA",          inline="8",   group=grp_sma)
col_8         = input.color(color.blue,   "",                    inline="8",   group=grp_sma)
width_8       = input.int(1, "",          minval=1, maxval=4,    inline="8",   group=grp_sma)

show_21       = input.bool(true,          "Show 21 SMA",         inline="21",  group=grp_sma)
col_21        = input.color(color.purple, "",                    inline="21",  group=grp_sma)
width_21      = input.int(2, "",          minval=1, maxval=4,    inline="21",  group=grp_sma)

show_200_5m   = input.bool(true,          "Show 5min 200 SMA",   inline="5m",  group=grp_sma)
col_200_5m    = input.color(color.orange, "",                    inline="5m",  group=grp_sma)
width_200_5m  = input.int(2, "",          minval=1, maxval=4,    inline="5m",  group=grp_sma)

show_200_10m  = input.bool(true,          "Show 10min 200 SMA",  inline="10m", group=grp_sma)
col_200_10m   = input.color(color.yellow, "",                    inline="10m", group=grp_sma)
width_200_10m = input.int(2, "",          minval=1, maxval=4,    inline="10m", group=grp_sma)

show_200_1h   = input.bool(true,          "Show Hourly 200 SMA", inline="1h",  group=grp_sma)
col_200_1h    = input.color(color.red,    "",                    inline="1h",  group=grp_sma)
width_200_1h  = input.int(2, "",          minval=1, maxval=4,    inline="1h",  group=grp_sma)

// =============================================================================
// INPUTS — VWAP
// =============================================================================
grp_vwap   = "VWAP"
show_vwap  = input.bool(true,        "Show VWAP", inline="vwap", group=grp_vwap)
col_vwap   = input.color(color.teal, "",          inline="vwap", group=grp_vwap)
width_vwap = input.int(2, "",        minval=1, maxval=4, inline="vwap", group=grp_vwap)

// =============================================================================
// INPUTS — PRE-MARKET LEVELS
// =============================================================================
grp_pm  = "Pre-Market Levels"
show_pm = input.bool(true,         "Show PMH / PML (last 5 days)", group=grp_pm)
col_pm  = input.color(color.white, "Line color",                   group=grp_pm)

// =============================================================================
// INPUTS — OPENING RANGE
// =============================================================================
grp_or  = "Opening Range"
show_or = input.bool(true, "Show Opening Range (9:30–9:45)", group=grp_or)

// =============================================================================
// INPUTS — PATIENCE CANDLE
// =============================================================================
grp_pc        = "Patience Candle"
show_pc       = input.bool(true,  "Show Patience Candle Arrows",         group=grp_pc)
warn_sma_dist = input.float(1.0,  "Hourly 200 SMA Warning Distance ($)", group=grp_pc, minval=0.1, step=0.25)

// =============================================================================
// INPUTS — SR CHANNELS
// =============================================================================
grp_sr        = "SR Channels"
show_sr       = input.bool(true,  "Show SR Channels",        group=grp_sr)
prd           = input.int(10,     "Pivot Period",             group=grp_sr, minval=4, maxval=30)
ppsrc         = input.string("High/Low", "Source",            group=grp_sr, options=["High/Low", "Close/Open"])
ChannelW      = input.int(5,      "Maximum Channel Width %",  group=grp_sr, minval=1, maxval=8)
minstrength   = input.int(1,      "Minimum Strength",         group=grp_sr, minval=1)
loopback_days = input.int(60,     "Loopback Period (Days)",   group=grp_sr, minval=5, maxval=365)

// =============================================================================
// SR LEVELS FUNCTION — runs entirely inside request.security("60", ...)
// This means the heavy clustering loop only executes when an HOURLY BAR CLOSES,
// never on intraday display bars. The returned scalars are identical on every
// display timeframe (2m, 5m, 10m, etc.) because the computation lives on the
// 1H chart, not on the display chart.
//
// Returns 20 scalars: 10 levels × (top, bottom).
// =============================================================================
get_sr_levels() =>
    float _src1  = ppsrc == "High/Low" ? high : math.max(close, open)
    float _src2  = ppsrc == "High/Low" ? low  : math.min(close, open)
    float ph_val = ta.pivothigh(_src1, prd, prd)
    float pl_val = ta.pivotlow(_src2,  prd, prd)
    float cw     = (ta.highest(300) - ta.lowest(300)) * ChannelW / 100

    // Exclude pivots from the current trading day (on or after 4 AM ET today)
    int cutoff = timestamp("America/New_York",
         year(timenow,       "America/New_York"),
         month(timenow,      "America/New_York"),
         dayofmonth(timenow, "America/New_York"), 4, 0)

    // var inside a function called via request.security persists across
    // hourly bars — this is how pivot history accumulates on the 1H chart
    var float[] pv = array.new_float(0)
    var float[] pt = array.new_float(0)

    if (bool(ph_val) or bool(pl_val)) and time < cutoff
        array.unshift(pv, bool(ph_val) ? ph_val : pl_val)
        array.unshift(pt, float(time))
        int sz = array.size(pv)
        while sz > 0
            if float(time) - array.get(pt, sz - 1) > loopback_days * 86400000
                array.pop(pv)
                array.pop(pt)
                sz -= 1
            else
                break
        while array.size(pv) > 100
            array.pop(pv)
            array.pop(pt)

    int npv = array.size(pv)

    // sr holds the top 10 clustered SR levels (top/bot pairs) — persists between hourly bars
    var float[] sr = array.new_float(20, 0.0)

    if npv > 0
        // Build a flat array: [strength, hi, lo] × npv
        float[] supres = array.new_float(0)
        for x = 0 to npv - 1
            float lo  = array.get(pv, x)
            float hi  = lo
            int numpp = 0
            for y = 0 to npv - 1
                float cpp  = array.get(pv, y)
                float wdth = cpp <= hi ? hi - cpp : cpp - lo
                if wdth <= cw
                    if cpp <= hi
                        lo := math.min(lo, cpp)
                    else
                        hi := math.max(hi, cpp)
                    numpp += 20
            array.push(supres, float(numpp))
            array.push(supres, hi)
            array.push(supres, lo)

        // Greedily pick the 10 strongest non-overlapping levels
        array.fill(sr, 0.0)
        int src = 0
        for x = 0 to npv - 1
            float stv = -1.0
            int   stl = -1
            for y = 0 to npv - 1
                if array.get(supres, y * 3) > stv and array.get(supres, y * 3) >= float(minstrength * 20)
                    stv := array.get(supres, y * 3)
                    stl := y
            if stl >= 0
                float hh = array.get(supres, stl * 3 + 1)
                float ll = array.get(supres, stl * 3 + 2)
                array.set(sr, src * 2,     hh)
                array.set(sr, src * 2 + 1, ll)
                for y = 0 to npv - 1
                    float yt = array.get(supres, y * 3 + 1)
                    float yb = array.get(supres, y * 3 + 2)
                    if (yt <= hh and yt >= ll) or (yb <= hh and yb >= ll)
                        array.set(supres, y * 3, -1.0)
                src += 1
                if src >= 10
                    break

    // Pine Script cannot return arrays from request.security — return 20 scalars
    [array.get(sr,  0), array.get(sr,  1),
     array.get(sr,  2), array.get(sr,  3),
     array.get(sr,  4), array.get(sr,  5),
     array.get(sr,  6), array.get(sr,  7),
     array.get(sr,  8), array.get(sr,  9),
     array.get(sr, 10), array.get(sr, 11),
     array.get(sr, 12), array.get(sr, 13),
     array.get(sr, 14), array.get(sr, 15),
     array.get(sr, 16), array.get(sr, 17),
     array.get(sr, 18), array.get(sr, 19)]

// =============================================================================
// MTF PATIENCE CANDLE DETECTION FUNCTION
// Self-contained — replicates PM level, trend, and suppression logic so it
// can be called via request.security on any timeframe independently.
// Returns [pc_long, pc_short] booleans on confirmed bars only.
// =============================================================================
get_pc_conditions() =>
    bool _is_pm    = session.ispremarket
    bool _is_reg   = session.ismarket
    bool _sess_open = _is_reg and not _is_reg[1]
    int  _et_hour   = hour(time, "America/New_York")
    bool _in_last_hour = _is_reg and _et_hour >= 15

    var float _pmh      = na
    var float _pml      = na
    var float _pmh_lock = na
    var float _pml_lock = na
    var bool  _locked   = false

    if _sess_open
        _pmh_lock := _pmh
        _pml_lock := _pml
        _pmh      := na
        _pml      := na
        _locked   := true
    if _is_pm
        _pmh    := na(_pmh) ? high : math.max(_pmh, high)
        _pml    := na(_pml) ? low  : math.min(_pml, low)
        _locked := false

    float _pmh_val = _locked ? _pmh_lock : _pmh
    float _pml_val = _locked ? _pml_lock : _pml

    var float _open_price = na
    if _sess_open
        _open_price := open

    float _ref_hi = na(_pmh_val) ? _open_price : _pmh_val
    float _ref_lo = na(_pml_val) ? _open_price : _pml_val

    var int _trend = 0
    if _sess_open
        _trend := 0
    if not na(_ref_hi) and close > _ref_hi and _trend == 0
        _trend := 1
    if not na(_ref_lo) and close < _ref_lo and _trend == 0
        _trend := -1

    var float _dhi = na
    var float _dlo = na
    if _sess_open
        _dhi := na
        _dlo := na
    if _is_reg
        _dhi := na(_dhi) ? high : math.max(_dhi, high)
        _dlo := na(_dlo) ? low  : math.min(_dlo, low)

    float _dr = not na(_dhi) and not na(_dlo) ? _dhi - _dlo : na
    float _rl = not na(_dr) and _dr > 0 ? _dhi - 0.40 * _dr : na
    float _rs = not na(_dr) and _dr > 0 ? _dlo + 0.40 * _dr : na

    var bool _sup_l = false
    var bool _sup_s = false
    if _sess_open
        _sup_l := false
        _sup_s := false
    if _is_reg and not na(_rs) and _trend == -1 and high >= _rs
        _sup_s := true
    if _is_reg and not na(_rl) and _trend == 1  and low  <= _rl
        _sup_l := true
    if _is_reg and not na(_dlo[1]) and low  < _dlo[1]
        _sup_s := false
    if _is_reg and not na(_dhi[1]) and high > _dhi[1]
        _sup_l := false

    bool _pc_long  = _is_reg and _trend == 1  and high < high[1] and high > _ref_hi and not _in_last_hour and not _sup_l and barstate.isconfirmed
    bool _pc_short = _is_reg and _trend == -1 and low  > low[1]  and low  < _ref_lo and not _in_last_hour and not _sup_s and barstate.isconfirmed
    [_pc_long, _pc_short]

// =============================================================================
// SECURITY CALLS
// =============================================================================
sma200_1h  = request.security(syminfo.tickerid, "60", ta.sma(close, 200))
sma200_5m  = request.security(syminfo.tickerid, "5",  ta.sma(close, 200))
sma200_10m = request.security(syminfo.tickerid, "10", ta.sma(close, 200))

// All SR computation lives on the 1H chart via get_sr_levels()
[sr0t, sr0b, sr1t, sr1b, sr2t, sr2b, sr3t, sr3b, sr4t, sr4b,
 sr5t, sr5b, sr6t, sr6b, sr7t, sr7b, sr8t, sr8b, sr9t, sr9b] =
     request.security(syminfo.tickerid, "60", get_sr_levels())

// MTF PC states — runs the full PC logic on each timeframe independently
[mtf_pc_long_2m,  mtf_pc_short_2m]  = request.security(syminfo.tickerid, "2",  get_pc_conditions())
[mtf_pc_long_5m,  mtf_pc_short_5m]  = request.security(syminfo.tickerid, "5",  get_pc_conditions())
[mtf_pc_long_10m, mtf_pc_short_10m] = request.security(syminfo.tickerid, "10", get_pc_conditions())

// =============================================================================
// MOVING AVERAGES
// =============================================================================
sma8  = ta.sma(close, 8)
sma21 = ta.sma(close, 21)

plot(show_8       ? sma8       : na, "8 SMA",          color=col_8,        linewidth=width_8)
plot(show_21      ? sma21      : na, "21 SMA",         color=col_21,       linewidth=width_21)
plot(show_200_5m  ? sma200_5m  : na, "5min 200 SMA",   color=col_200_5m,   linewidth=width_200_5m)
plot(show_200_10m ? sma200_10m : na, "10min 200 SMA",  color=col_200_10m,  linewidth=width_200_10m)
plot(show_200_1h  ? sma200_1h  : na, "Hourly 200 SMA", color=col_200_1h,   linewidth=width_200_1h)

// =============================================================================
// VWAP
// =============================================================================
vwap_val = ta.vwap(hlc3)
plot(show_vwap ? vwap_val : na, "VWAP", color=col_vwap, linewidth=width_vwap)

// =============================================================================
// SESSION DETECTION
// =============================================================================
bool is_premarket  = session.ispremarket
bool is_regular    = session.ismarket
bool session_open  = is_regular and not is_regular[1]
bool session_close = not is_regular and is_regular[1]

// =============================================================================
// TIME OF DAY (ET)
// =============================================================================
int et_hour   = hour(time, "America/New_York")
int et_minute = minute(time, "America/New_York")

bool in_or         = is_regular and et_hour == 9 and et_minute < 45
bool or_just_ended = is_regular and not in_or and in_or[1]
bool in_last_hour  = is_regular and et_hour >= 15

// =============================================================================
// PRE-MARKET HIGH / LOW — last 5 trading days, scoped per day
// =============================================================================
var float pm_high        = na
var float pm_low         = na
var float pm_high_locked = na
var float pm_low_locked  = na
var bool  pm_locked      = false

if session_open
    pm_high_locked := pm_high
    pm_low_locked  := pm_low
    pm_high        := na
    pm_low         := na
    pm_locked      := true

if is_premarket
    pm_high   := na(pm_high) ? high : math.max(pm_high, high)
    pm_low    := na(pm_low)  ? low  : math.min(pm_low,  low)
    pm_locked := false

float pmh = pm_locked ? pm_high_locked : pm_high
float pml = pm_locked ? pm_low_locked  : pm_low

var line[]  pmh_lines  = array.new<line>()
var line[]  pml_lines  = array.new<line>()
var label[] pmh_labels = array.new<label>()
var label[] pml_labels = array.new<label>()
var line    pmh_cur    = na
var line    pml_cur    = na

if show_pm and session_open and not na(pmh) and not na(pml)
    pmh_cur := line.new(bar_index, pmh, bar_index + 1, pmh, color=col_pm, width=1, style=line.style_solid, extend=extend.right)
    pml_cur := line.new(bar_index, pml, bar_index + 1, pml, color=col_pm, width=1, style=line.style_solid, extend=extend.right)
    array.push(pmh_lines, pmh_cur)
    array.push(pml_lines, pml_cur)
    label lh = label.new(bar_index, pmh, "PMH " + str.tostring(pmh, "#.##"),
         color=color.new(color.white, 100), textcolor=col_pm, size=size.small, style=label.style_label_right)
    label ll = label.new(bar_index, pml, "PML " + str.tostring(pml, "#.##"),
         color=color.new(color.white, 100), textcolor=col_pm, size=size.small, style=label.style_label_right)
    array.push(pmh_labels, lh)
    array.push(pml_labels, ll)
    while array.size(pmh_lines) > 5
        line.delete(array.shift(pmh_lines))
        line.delete(array.shift(pml_lines))
        label.delete(array.shift(pmh_labels))
        label.delete(array.shift(pml_labels))

if show_pm and session_close and not na(pmh_cur)
    line.set_extend(pmh_cur, extend.none)
    line.set_x2(pmh_cur, bar_index)
if show_pm and session_close and not na(pml_cur)
    line.set_extend(pml_cur, extend.none)
    line.set_x2(pml_cur, bar_index)

// =============================================================================
// OPENING RANGE HIGH / LOW — drawn at 9:45, grows with each new candle
// =============================================================================
var float or_high      = na
var float or_low       = na
var line  or_high_line = na
var line  or_low_line  = na

if session_open
    or_high      := na
    or_low       := na
    or_high_line := na
    or_low_line  := na

if in_or
    or_high := na(or_high) ? high : math.max(or_high, high)
    or_low  := na(or_low)  ? low  : math.min(or_low,  low)

if show_or and or_just_ended and not na(or_high)
    or_high_line := line.new(bar_index, or_high, bar_index, or_high, color=color.lime, width=2, style=line.style_solid)
    or_low_line  := line.new(bar_index, or_low,  bar_index, or_low,  color=color.lime, width=2, style=line.style_solid)

if show_or and is_regular and not in_or and not na(or_high_line)
    line.set_x2(or_high_line, bar_index)
    line.set_x2(or_low_line,  bar_index)

// =============================================================================
// TREND DIRECTION
// =============================================================================
var float sess_open_price = na
if session_open
    sess_open_price := open

float ref_high = na(pmh) ? sess_open_price : pmh
float ref_low  = na(pml) ? sess_open_price : pml

bool above_ref = not na(ref_high) and close > ref_high
bool below_ref = not na(ref_low)  and close < ref_low

bool above_pm = not na(pmh) and close > pmh
bool below_pm = not na(pml) and close < pml

var int trend_dir = 0
if session_open
    trend_dir := 0
if above_ref and trend_dir == 0
    trend_dir := 1
if below_ref and trend_dir == 0
    trend_dir := -1

// =============================================================================
// SESSION HIGH / LOW (for 40% retracement filter)
// =============================================================================
var float day_high = na
var float day_low  = na

if session_open
    day_high := na
    day_low  := na

if is_regular
    day_high := na(day_high) ? high : math.max(day_high, high)
    day_low  := na(day_low)  ? low  : math.min(day_low,  low)

// =============================================================================
// PATIENCE CANDLE DETECTION
// =============================================================================
bool valid_tf = timeframe.period == "2" or timeframe.period == "5" or timeframe.period == "10"

bool pc_long_valid  = is_regular and valid_tf and trend_dir == 1
     and high <  high[1] and high > ref_high
     and not in_last_hour and barstate.isconfirmed

bool pc_short_valid = is_regular and valid_tf and trend_dir == -1
     and low  >  low[1]  and low  < ref_low
     and not in_last_hour and barstate.isconfirmed

bool pc_long_done  = is_regular and valid_tf and trend_dir == 1  and high >= high[1]
bool pc_short_done = is_regular and valid_tf and trend_dir == -1 and low  <= low[1]

float day_range     = not na(day_high) and not na(day_low) ? day_high - day_low : na
float retrace_long  = not na(day_range) and day_range > 0 ? day_high - 0.40 * day_range : na
float retrace_short = not na(day_range) and day_range > 0 ? day_low  + 0.40 * day_range : na

var bool suppress_long  = false
var bool suppress_short = false

if session_open
    suppress_long  := false
    suppress_short := false

if is_regular and not na(retrace_short) and trend_dir == -1 and high >= retrace_short
    suppress_short := true
if is_regular and not na(retrace_long)  and trend_dir == 1  and low  <= retrace_long
    suppress_long  := true

if is_regular and not na(day_low[1])  and low  < day_low[1]
    suppress_short := false
if is_regular and not na(day_high[1]) and high > day_high[1]
    suppress_long  := false

float atr_val = ta.atr(14)
float tri_h   = atr_val * 0.40
float tri_gap = atr_val * 0.08

bool warn_long  = not na(sma200_1h) and sma200_1h > high and sma200_1h - high <= warn_sma_dist
bool warn_short = not na(sma200_1h) and sma200_1h < low  and low - sma200_1h  <= warn_sma_dist

// A+ = PC on 5min AND (PC on 2min OR PC on 10min) — visible on any chart TF
bool aplus_long  = mtf_pc_long_5m  and (mtf_pc_long_2m  or mtf_pc_long_10m)
bool aplus_short = mtf_pc_short_5m and (mtf_pc_short_2m or mtf_pc_short_10m)

var polyline pc_poly      = na
var label    pc_warn      = na
var label    pc_aplus_lbl = na

if session_open
    polyline.delete(pc_poly)
    label.delete(pc_warn)
    label.delete(pc_aplus_lbl)
    pc_poly      := na
    pc_warn      := na
    pc_aplus_lbl := na

bool retrace_short_hit = trend_dir == -1 and suppress_short and not suppress_short[1]
bool retrace_long_hit  = trend_dir == 1  and suppress_long  and not suppress_long[1]
bool retrace_just_hit  = retrace_short_hit or retrace_long_hit

if pc_long_done or pc_short_done or retrace_just_hit
    polyline.delete(pc_poly)
    label.delete(pc_warn)
    label.delete(pc_aplus_lbl)
    pc_poly      := na
    pc_warn      := na
    pc_aplus_lbl := na

if show_pc and pc_long_valid and not suppress_long
    polyline.delete(pc_poly)
    label.delete(pc_warn)
    label.delete(pc_aplus_lbl)
    pc_warn      := na
    pc_aplus_lbl := na
    color tri_fill_long = aplus_long ? color.new(color.orange, 0) : color.new(color.green, 0)
    color tri_line_long = warn_long  ? color.yellow : tri_fill_long
    pc_poly := polyline.new(
         array.from(
             chart.point.from_index(bar_index,     low - tri_gap),
             chart.point.from_index(bar_index - 1, low - tri_gap - tri_h),
             chart.point.from_index(bar_index + 1, low - tri_gap - tri_h)),
         closed=true,
         fill_color=tri_fill_long,
         line_color=tri_line_long)
    if warn_long
        pc_warn := label.new(bar_index, low - tri_gap - tri_h - (atr_val * 0.08), "!",
             style=label.style_none, textcolor=color.yellow, size=size.huge)
    if aplus_long
        pc_aplus_lbl := label.new(bar_index, low - tri_gap - tri_h - (atr_val * 0.08), "A+",
             style=label.style_none, textcolor=color.orange, size=size.normal)

else if show_pc and pc_short_valid and not suppress_short
    polyline.delete(pc_poly)
    label.delete(pc_warn)
    label.delete(pc_aplus_lbl)
    pc_warn      := na
    pc_aplus_lbl := na
    color tri_fill_short = aplus_short ? color.new(color.orange, 0) : color.new(color.red, 0)
    color tri_line_short = warn_short  ? color.yellow : tri_fill_short
    pc_poly := polyline.new(
         array.from(
             chart.point.from_index(bar_index,     high + tri_gap),
             chart.point.from_index(bar_index - 1, high + tri_gap + tri_h),
             chart.point.from_index(bar_index + 1, high + tri_gap + tri_h)),
         closed=true,
         fill_color=tri_fill_short,
         line_color=tri_line_short)
    if warn_short
        pc_warn := label.new(bar_index, high + tri_gap + tri_h + (atr_val * 0.08), "!",
             style=label.style_none, textcolor=color.yellow, size=size.huge)
    if aplus_short
        pc_aplus_lbl := label.new(bar_index, high + tri_gap + tri_h + (atr_val * 0.08), "A+",
             style=label.style_none, textcolor=color.orange, size=size.normal)

// =============================================================================
// SR CHANNELS — draw at session open, fixed for the day
// sr0t..sr9t / sr0b..sr9b are the 10 level tops/bottoms from the 1H chart.
// Classify above/below using the session open price — identical on all TFs.
// =============================================================================
var line[] sr_top = array.new_line(10)
var line[] sr_bot = array.new_line(10)

if show_sr and session_open
    // Delete prior day's lines
    for x = 0 to 9
        line.delete(array.get(sr_top, x))
        line.delete(array.get(sr_bot, x))
        array.set(sr_top, x, na)
        array.set(sr_bot, x, na)

    // Pack the 20 scalars back into arrays for sorting/filtering
    float[] all_t = array.from(sr0t, sr1t, sr2t, sr3t, sr4t, sr5t, sr6t, sr7t, sr8t, sr9t)
    float[] all_b = array.from(sr0b, sr1b, sr2b, sr3b, sr4b, sr5b, sr6b, sr7b, sr8b, sr9b)

    float[] above_t = array.new_float(0)
    float[] above_b = array.new_float(0)
    float[] below_t = array.new_float(0)
    float[] below_b = array.new_float(0)

    bool has_pm = not na(pmh) and not na(pml)

    for x = 0 to 9
        float t = array.get(all_t, x)
        float b = array.get(all_b, x)
        if t != 0.0 and b != 0.0
            bool in_pm = has_pm and b >= pml and t <= pmh
            if not in_pm
                float mid = (t + b) / 2
                if mid >= open
                    array.push(above_t, t)
                    array.push(above_b, b)
                else
                    array.push(below_t, t)
                    array.push(below_b, b)

    // Sort above ascending by bottom (closest above first)
    int asiz = array.size(above_b)
    if asiz >= 2
        for i = 0 to asiz - 2
            for j = 0 to asiz - 2 - i
                if array.get(above_b, j) > array.get(above_b, j + 1)
                    float tt = array.get(above_t, j)
                    float tb = array.get(above_b, j)
                    array.set(above_t, j, array.get(above_t, j + 1))
                    array.set(above_b, j, array.get(above_b, j + 1))
                    array.set(above_t, j + 1, tt)
                    array.set(above_b, j + 1, tb)

    // Sort below descending by top (closest below first)
    int bsiz = array.size(below_b)
    if bsiz >= 2
        for i = 0 to bsiz - 2
            for j = 0 to bsiz - 2 - i
                if array.get(below_t, j) < array.get(below_t, j + 1)
                    float tt = array.get(below_t, j)
                    float tb = array.get(below_b, j)
                    array.set(below_t, j, array.get(below_t, j + 1))
                    array.set(below_b, j, array.get(below_b, j + 1))
                    array.set(below_t, j + 1, tt)
                    array.set(below_b, j + 1, tb)

    // Anchor left endpoint far back so origin is visible; extend right through session
    int hist_x = math.max(0, bar_index - 2000)
    int slot   = 0
    int da     = math.min(5, array.size(above_t))
    int db     = math.min(5, array.size(below_t))

    if da > 0
        for x = 0 to da - 1
            if slot < 10
                array.set(sr_top, slot, line.new(hist_x, array.get(above_t, x), bar_index, array.get(above_t, x),
                     extend=extend.right, color=color.yellow, width=1, style=line.style_solid))
                array.set(sr_bot, slot, line.new(hist_x, array.get(above_b, x), bar_index, array.get(above_b, x),
                     extend=extend.right, color=color.yellow, width=1, style=line.style_solid))
                slot += 1

    if db > 0
        for x = 0 to db - 1
            if slot < 10
                array.set(sr_top, slot, line.new(hist_x, array.get(below_t, x), bar_index, array.get(below_t, x),
                     extend=extend.right, color=color.yellow, width=1, style=line.style_solid))
                array.set(sr_bot, slot, line.new(hist_x, array.get(below_b, x), bar_index, array.get(below_b, x),
                     extend=extend.right, color=color.yellow, width=1, style=line.style_solid))
                slot += 1

// Cap lines at session close — no bleed into next day's pre-market
if show_sr and session_close
    for x = 0 to 9
        if not na(array.get(sr_top, x))
            line.set_extend(array.get(sr_top, x), extend.none)
            line.set_x2(array.get(sr_top, x), bar_index)
        if not na(array.get(sr_bot, x))
            line.set_extend(array.get(sr_bot, x), extend.none)
            line.set_x2(array.get(sr_bot, x), bar_index)

// =============================================================================
// ALERTS
// =============================================================================
alertcondition(pc_long_valid  and not pc_long_valid[1],
     "Patience Candle - LONG",
     "Long patience candle. Entry above PC high, stop below PC low.")

alertcondition(pc_short_valid and not pc_short_valid[1],
     "Patience Candle - SHORT",
     "Short patience candle. Entry below PC low, stop above PC high.")

alertcondition(above_pm and not above_pm[1],
     "PM Breakout - LONG",  "Price broke above pre-market high.")

alertcondition(below_pm and not below_pm[1],
     "PM Breakout - SHORT", "Price broke below pre-market low.")

// SR break alerts — check against all 10 returned level scalars
float[] _at = array.from(sr0t, sr1t, sr2t, sr3t, sr4t, sr5t, sr6t, sr7t, sr8t, sr9t)
float[] _ab = array.from(sr0b, sr1b, sr2b, sr3b, sr4b, sr5b, sr6b, sr7b, sr8b, sr9b)

bool sr_resistance_broken = false
bool sr_support_broken    = false
bool sr_not_in_channel    = true

for x = 0 to 9
    float t = array.get(_at, x)
    float b = array.get(_ab, x)
    if t != 0.0 and b != 0.0 and close <= t and close >= b
        sr_not_in_channel := false

if sr_not_in_channel
    for x = 0 to 9
        float t = array.get(_at, x)
        float b = array.get(_ab, x)
        if t != 0.0 and b != 0.0
            if close[1] <= t and close > t
                sr_resistance_broken := true
            if close[1] >= b and close < b
                sr_support_broken := true

alertcondition(sr_resistance_broken, title="SR Resistance Broken", message="SR Resistance Broken")
alertcondition(sr_support_broken,    title="SR Support Broken",    message="SR Support Broken")
